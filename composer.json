{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "webkernel/standard-paths",
    "description": "Core environment path locator and configuration cache system for the Webkernel platform.",
    "version": "0.12.0",
    "homepage": "https://www.webkernelphp.com/",
    "type": "webkernel-stdlib",
    "license": "EPL-2.0",
    "authors": [
        {
            "name": "El Moumen Yassine",
            "email": "yassine@numerimondes.com",
            "homepage": "https://webkernelphp.com/about"
        }
    ],
    "support": {
        "issues": "https://github.com/webkernelphp/standard-paths/issues"
    },
    "require": {
        "composer/composer": "^2.0",
        "composer/installers": "^2.0",
        "composer-plugin-api": "^2.0",
        "webkernel/standard-lifecycle": "0.12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^7.2",
        "squizlabs/php_codesniffer": "^3.3"
    },
    "autoload": {
        "files": [
            "load.standard-paths.functions.php"
        ],
        "classmap": [],
        "psr-4": {
            "Webkernel\\StdPaths\\": "src/"
        }
    },
    "scripts": {
        "fix": "vendor/bin/phpcbf",
        "lint": "vendor/bin/phpcs",
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "webkernel": {
            "package_repo": "git@github.com:webkernelphp/standard-paths.git",
            "prefix": "standard"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
