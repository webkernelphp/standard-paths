{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "webkernel/standard-locator",
    "description": "Core environment path locator and configuration cache system for the Webkernel platform.",
    "version": "0.1.0",
    "homepage": "https://www.webkernelphp.com/",
    "type": "composer-plugin",
    "license": "EPL-2.0",
    "authors": [
        {
            "name": "El Moumen Yassine",
            "email": "yassine@numerimondes.com",
            "homepage": "https://webkernelphp.com/about"
        }
    ],
    "support": {
        "issues": "https://github.com/webkernelphp/stdloc/issues"
    },
    "require": {
        "composer/composer": "^2.0",
        "composer/installers": "^2.0",
        "composer-plugin-api": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^7.2",
        "squizlabs/php_codesniffer": "^3.3"
    },
    "autoload": {
        "files": [
            "load.stdloc.functions.php"
        ],
        "classmap": [],
        "psr-4": {
            "Webkernel\\StdLoc\\": "src/"
        }
    },
    "scripts": {
        "fix": "vendor/bin/phpcbf",
        "lint": "vendor/bin/phpcs",
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.4.0"
        }
    },
    "extra": {
        "class": "Webkernel\\StdLoc\\Composer\\Plugin",
        "webkernel": {
            "split_repo": "git@github.com:webkernelphp/standard-locator.git",
            "production": true,
            "prefix": "standard"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}